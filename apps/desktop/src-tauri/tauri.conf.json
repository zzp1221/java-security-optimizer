{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Java Security Optimizer",
  "version": "0.1.0",
  "identifier": "com.project.javasecurityoptimizer.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../web-ui run dev",
    "beforeBuildCommand": "npm --prefix ../web-ui run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Java Security Optimizer",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
